# Neon Postgres (use pooler URL for serverless / Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js v5
AUTH_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\""
# Local:
AUTH_URL="http://localhost:3000"
# Production (Vercel):
# AUTH_URL="https://task-flow-fullstack-crud-profession.vercel.app"
AUTH_TRUST_HOST="true"

# GitHub OAuth App
# Callback (production): https://task-flow-fullstack-crud-profession.vercel.app/api/auth/callback/github
# Callback (local):      http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
